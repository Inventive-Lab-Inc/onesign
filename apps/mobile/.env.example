# Supabase (same as web NEXT_PUBLIC_*)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Web app origin for uploads / billing deep links
APP_URL=https://app.onesigntv.com

# Public media CDN base (MinIO)
MEDIA_BASE_URL=https://storage.onesigntv.com/onesign-media

# Web Google OAuth client ID (Auth.js AUTH_GOOGLE_ID) — used as serverClientId for ID tokens
GOOGLE_SERVER_CLIENT_ID=
# Required for Google Sign-In on iOS — Google Cloud → Credentials → iOS OAuth client
# Bundle ID must be: tv.onesign.onesignConsole
# After setting, run: ../../scripts/sync-ios-google-signin.sh
GOOGLE_IOS_CLIENT_ID=
