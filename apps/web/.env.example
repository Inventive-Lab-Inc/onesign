# Supabase project — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Same values as above (Vercel / server; runtime — helps if a build was made before NEXT_PUBLIC_ was set)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=YOUR_ANON_KEY

# MinIO public read URLs (path-style, includes bucket name)
NEXT_PUBLIC_MEDIA_BASE_URL=https://storage.onesigntv.com/onesign-media
NEXT_PUBLIC_RELEASES_BASE_URL=https://storage.onesigntv.com/onesign-releases

# MinIO server credentials (upload/delete API routes only — never expose as NEXT_PUBLIC_)
S3_ENDPOINT=https://storage.onesigntv.com
S3_REGION=us-east-1
S3_MEDIA_BUCKET=onesign-media
S3_RELEASES_BUCKET=onesign-releases
S3_ACCESS_KEY=your-minio-access-key
S3_SECRET_KEY=your-minio-secret-key
S3_FORCE_PATH_STYLE=true

# VPS deploy (deploy-onesign skill — Agent/shell only, not read by Next.js)
ONESIGN_VPS_HOST=your-vps-ip
ONESIGN_VPS_USER=root
ONESIGN_VPS_PASSWORD=your-vps-password
# ONESIGN_VPS_SSH_KEY_PATH=/path/to/private_key
ONESIGN_MINIO_MC_ALIAS=local
ONESIGN_MINIO_RELEASES_BUCKET=onesign-releases

# Optional: marketing site origin (landing). Defaults to https://onesigntv.com
# NEXT_PUBLIC_MARKETING_URL=https://onesigntv.com

# Microsoft Clarity (https://clarity.microsoft.com/) — session recordings & heatmaps
# NEXT_PUBLIC_CLARITY_MARKETING_PROJECT_ID=your-marketing-clarity-project-id
# NEXT_PUBLIC_CLARITY_APP_PROJECT_ID=your-app-clarity-project-id
# Legacy alias for marketing only:
# NEXT_PUBLIC_CLARITY_PROJECT_ID=your-marketing-clarity-project-id

# Canonical app origin (login, dashboard, auth emails). Browser auth uses the active origin on app host.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/confirm
#   https://app.onesigntv.com/auth/confirm

# Google sign-in (Auth.js — direct Google OAuth, not Supabase OAuth)
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=replace-with-random-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Google Cloud Console → OAuth client → Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://app.onesigntv.com/api/auth/callback/google

# Bridge Google users into Supabase sessions (server-only — never NEXT_PUBLIC_)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local dev only — if server-side HTTPS fails with SELF_SIGNED_CERT_IN_CHAIN
# (Supabase, MinIO image optimizer, S3 uploads). Never set in production.
# SUPABASE_INSECURE_TLS=true
# DEV_INSECURE_TLS=true

# Dashboard: background pull from Supabase (ms). Minimum 15000. Default 120000 (2 min).
# NEXT_PUBLIC_CONSOLE_SYNC_INTERVAL_MS=120000

# Stripe — Dashboard → Developers → API keys (use test keys locally)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
# Webhook signing secret — Dashboard → Webhooks, or `stripe listen` locally
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
