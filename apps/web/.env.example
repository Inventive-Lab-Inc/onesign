# Supabase project — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Same values as above (Vercel / server; runtime — helps if a build was made before NEXT_PUBLIC_ was set)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=YOUR_ANON_KEY

# MinIO public read URLs (path-style, includes bucket name)
NEXT_PUBLIC_MEDIA_BASE_URL=https://s3.storage.inventivelab.bd/onesign-media
NEXT_PUBLIC_RELEASES_BASE_URL=https://s3.storage.inventivelab.bd/onesign-releases

# MinIO server credentials (upload/delete API routes only — never expose as NEXT_PUBLIC_)
S3_ENDPOINT=https://s3.storage.inventivelab.bd
S3_REGION=us-east-1
S3_MEDIA_BUCKET=onesign-media
S3_RELEASES_BUCKET=onesign-releases
S3_ACCESS_KEY=your-minio-access-key
S3_SECRET_KEY=your-minio-secret-key
S3_FORCE_PATH_STYLE=true

# Optional: absolute public URL for emails or absolute links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/confirm
#   https://YOUR_PRODUCTION_DOMAIN/auth/confirm

# Google sign-in (Auth.js — direct Google OAuth, not Supabase OAuth)
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=replace-with-random-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Google Cloud Console → OAuth client → Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://YOUR_PRODUCTION_DOMAIN/api/auth/callback/google

# Bridge Google users into Supabase sessions (server-only — never NEXT_PUBLIC_)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local dev only — if server-side Supabase calls fail with SELF_SIGNED_CERT_IN_CHAIN
# SUPABASE_INSECURE_TLS=true

# Dashboard: background pull from Supabase (ms). Minimum 15000. Default 120000 (2 min).
# NEXT_PUBLIC_CONSOLE_SYNC_INTERVAL_MS=120000
