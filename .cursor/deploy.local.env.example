# Local deploy secrets for the deploy-onesign skill (NEVER commit deploy.local.env).
# Copy: cp .cursor/deploy.local.env.example .cursor/deploy.local.env
# Or add the same ONESIGN_VPS_* keys to apps/web/.env.local (also gitignored).

# VPS SSH — used for scp + mc upload during Android OTA
ONESIGN_VPS_HOST=194.164.91.252
ONESIGN_VPS_USER=root
ONESIGN_VPS_PASSWORD=your-vps-password
# Optional: use key auth instead of password (leave password empty if set)
ONESIGN_VPS_SSH_KEY_PATH=

# MinIO `mc` alias configured on the VPS (see scripts/vps-setup-minio.sh)
ONESIGN_MINIO_MC_ALIAS=local
ONESIGN_MINIO_RELEASES_BUCKET=onesign-releases

# Optional: upload APK via S3 API instead of SSH (same keys as apps/web/.env.local)
# S3_ENDPOINT=https://s3.storage.inventivelab.bd
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_RELEASES_BUCKET=onesign-releases
# S3_FORCE_PATH_STYLE=true
